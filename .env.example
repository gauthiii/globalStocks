# ---- LLM providers (set one or both; toggle live from the dashboard) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=anthropic
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # Agent 2: analysis (web search)
# OPENAI_MODEL=gpt-4o-mini                     # Agent 2: analysis (web search)
# Optional — Agent 1: prompt generator. Defaults to the analysis models above.
# ANTHROPIC_PROMPT_MODEL=claude-sonnet-4-6
# OPENAI_PROMPT_MODEL=gpt-4o

# ---- Telegram alerts (optional) ----
# 1. In Telegram, message @BotFather, send /newbot, follow prompts -> copy the token below.
# 2. Message your new bot once (say "hi"), then open:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  and copy "chat":{"id": ...} below.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=